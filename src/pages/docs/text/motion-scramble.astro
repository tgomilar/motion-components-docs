---
import Layout from "../../../layouts/Layout.astro";
import DocsPreview from "../../../components/DocsPreview.astro";
import DocsSidebar from "../../../components/DocsSidebar.astro";
import DocsTOC from "../../../components/DocsTOC.astro";
import DocsPagination from "../../../components/DocsPagination.astro";
import CodeWindow from "../../../components/CodeWindow.astro";
import PropsTable from "../../../components/PropsTable.astro";
import "../../../styles/docs.css";
---

<Layout title="motion-scramble — Motion Components" description="Scrambles text with random characters then progressively reveals the real text from left to right. Trigger on scroll or on hover." noMain>
  <div class="layout">
    <DocsSidebar />

    <main>
      <h1><motion-split by="chars" interval="0.025" duration="0.5">motion-scramble</motion-split></h1>
      <p class="lead">Scrambles text with random characters then progressively reveals the real text from left to right. Trigger on scroll or on hover.</p>

      <h2>Preview</h2>
      <DocsPreview replayId="scramble-demo">
        <motion-scramble id="scramble-demo" speed="40" iterations="2" class="demo-text"> Hello, world. </motion-scramble>
      </DocsPreview>

      <h2>Import</h2>
      <CodeWindow
        filename="app.ts"
        copy
        code={`import 'motion-components/motion-scramble'   // just this one
import 'motion-components'               // or the whole library`}
      />

      <h2>Usage</h2>
      <CodeWindow
        filename="motion-scramble.html"
        copy
        code={`<motion-scramble hover>
  Hover to scramble
</motion-scramble>`}
      />

      <h2>Properties</h2>
      <PropsTable nameLabel="Attribute" rows={[
        { name: 'speed', type: 'number', default: '40', description: 'Milliseconds between scramble frames' },
        { name: 'delay', type: 'number', default: '0', description: 'Delay before starting (ms)' },
        { name: 'iterations', type: 'number', default: '2', description: 'Scramble frames per character before revealing' },
        { name: 'hover', type: 'boolean', default: 'false', description: 'Trigger on mouseenter instead of scroll' },
        { name: 'once', type: 'boolean', default: 'true', description: 'Animate only on first intersection' },
      ]} />
      <h2>Accessibility</h2>
      <p>Respects <code>prefers-reduced-motion</code>: when enabled, the scramble effect is skipped and the text appears at its final state immediately.</p>
      <DocsPagination />
    </main>
      <DocsTOC />
  </div>
</Layout>

<script>
  import "motion-components";
</script>

<style>
  .demo-text {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    font-family: var(--font-mono);
  }
</style>
