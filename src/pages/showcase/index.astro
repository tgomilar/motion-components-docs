      font-weight: 700;
      font-size: 1.05rem;
      letter-spacing: -0.01em;
      color: var(--sc-ink);
      text-decoration: none;
      transition:
        color 0.15s,
        gap 0.18s;
    }

    .sc-arc-link:hover {
      color: var(--sc-accent);
      gap: 0.6rem;
    }

    .sc-arc-link-arrow {
      font-size: 0.95rem;
      color: var(--sc-yellow);
      text-shadow: 0 0 10px var(--sc-glow-cyan);
    }

    .sc-arc-link-cap {
      grid-column: 1 / -1;
      font-size: 0.82rem;
      line-height: 1.55;
      color: var(--sc-mute);
    }

    .sc-arc-showcase {
      display: inline-block;
      margin-left: 0.55rem;
      padding: 0.12rem 0.5rem;
      border: 1px solid var(--sc-yellow);
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--sc-yellow);
      text-decoration: none;
      transition:
        background 0.18s,
        color 0.18s,
        box-shadow 0.18s;
    }

    .sc-arc-showcase:hover {
      background: var(--sc-yellow);
      color: var(--sc-paper);
      box-shadow: 0 0 14px var(--sc-glow-cyan);
    }

    .sc-arc-orn {
      pointer-events: none;
    }

    .sc-arc {
      color: var(--sc-accent);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      filter: drop-shadow(0 0 8px var(--sc-glow-magenta));
    }

    .sc-curve-break {
      padding: 3rem 0;
      overflow: hidden;
      pointer-events: none;
    }

    .sc-curve {
      color: var(--sc-yellow);
      font-size: clamp(0.85rem, 1.5vw, 1.05rem);
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      filter: drop-shadow(0 0 10px var(--sc-glow-cyan));
      opacity: 0.85;
    }

    /* keep section content above parallax layers */
    .sc-hero,
    .sc-manifesto-grid,
    .sc-numbers > *:not(.sc-numbers-bg),
    .sc-words > *:not(.sc-words-bg),
    .sc-touch > *:not(.sc-touch-bg),
    .sc-cta > *:not(.sc-cta-bg) {
      position: relative;
      z-index: 1;
    }

    .sc-numbers,
    .sc-words,
    .sc-touch,
    .sc-cta {
      position: relative;
    }

    .sc * {
      box-sizing: border-box;
    }

    .sc-eyebrow {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--sc-mute);
      margin: 0 0 1rem;
    }

    .sc-eyebrow--alt {
      color: var(--sc-accent);
      text-shadow: 0 0 14px var(--sc-glow-magenta);
    }

    .sc-section-h {
      font-size: clamp(2rem, 4.4vw, 3.2rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.04;
      margin: 0 0 0.85rem;
      color: var(--sc-ink);
      text-shadow: 0 0 32px rgba(240, 238, 252, 0.18);
    }

    .sc-section-sub {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--sc-mute);
      max-width: 56ch;
      margin: 0 0 3rem;
    }

    /* ── HERO ─────────────────────────────────────── */
    .sc-hero-spot {
      display: block;
      border-radius: 0;
    }

    .sc-hero {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(5rem, 12vw, 9rem) clamp(1.25rem, 4vw, 3rem) clamp(4rem, 8vw, 6rem);
      position: relative;
    }

    .sc-hero-orn {
      position: absolute;
      top: clamp(3rem, 8vw, 6rem);
      right: clamp(1.25rem, 4vw, 3rem);
      width: 160px;
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: auto;
    }

    .sc-orn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .sc-orn-dot {
      font-size: 1.4rem;
      color: var(--sc-yellow);
      text-shadow:
        0 0 18px var(--sc-glow-cyan),
        0 0 36px var(--sc-glow-cyan);
    }

    .sc-h1 {
      font-family: var(--font-sans);
      font-size: clamp(2.8rem, 9vw, 7.5rem);
      font-weight: 800;
      letter-spacing: -0.05em;
      line-height: 0.95;
      color: var(--sc-ink);
      margin: 1.5rem 0 2rem;
      text-shadow: 0 0 60px rgba(240, 238, 252, 0.25);
      display: flex;
    }

    .sc-h1 motion-parallax {
      display: block;
      width: 100%;
    }

    .sc-h1 motion-split {
      display: block;
    }

    .sc-h1-italic {
      font-family: var(--sc-serif);
      font-style: italic;
      font-weight: 500;
      color: var(--sc-accent);
      letter-spacing: -0.02em;
      text-shadow:
        0 0 30px var(--sc-glow-magenta),
        0 0 60px var(--sc-glow-magenta);
    }

    .sc-hero-sub {
      display: block;
      max-width: 56ch;
      margin-bottom: 1.75rem;
    }

    .sc-hero-sub p {
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--sc-mute);
      margin: 0;
    }

    .sc-hero-sub code {
      font-size: 0.86em;
      color: var(--sc-accent);
      background: color-mix(in srgb, var(--sc-accent) 10%, transparent);
      padding: 0.1em 0.4em;
      border-radius: 4px;
    }

    .sc-hero-meta {
      display: block;
    }

    .sc-meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem 0.75rem;
      align-items: center;
      padding: 0.6rem 0;
      border-top: 1px solid var(--sc-rule);
      border-bottom: 1px solid var(--sc-rule);
      margin-bottom: 2.5rem;
    }

    .sc-meta-tag {
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      color: var(--sc-mute);
    }

    .sc-meta-dot {
      color: var(--sc-rule);
      font-size: 0.85rem;
    }

    .sc-hero-cycler {
      display: inline-flex;
      align-items: baseline;
      gap: 0.4rem;
      font-size: 1.15rem;
      font-weight: 600;
    }

    .sc-cycler-prefix {
      color: var(--sc-mute);
      font-size: 0.85rem;
      letter-spacing: 0.06em;
    }

    .sc-cycler-word {
      font-family: var(--sc-serif);
      font-style: italic;
      font-size: 1.4rem;
      letter-spacing: -0.01em;
    }

    .sc-hero-scramble {
      display: inline-block;
      color: var(--sc-yellow);
      font-weight: 600;
      text-shadow: 0 0 14px var(--sc-glow-cyan);
    }

    .sc-h1-and {
      color: var(--sc-yellow);
      text-shadow:
        0 0 24px var(--sc-glow-cyan),
        0 0 48px var(--sc-glow-cyan);
    }

    .sc-inline-word {
      color: var(--sc-accent);
      font-weight: 600;
      text-shadow: 0 0 10px var(--sc-glow-magenta);
    }

    .sc-aside-name--small {
      font-size: 1rem;
      color: var(--sc-mute);
      letter-spacing: 0;
    }

    /* ── MANIFESTO ────────────────────────────────── */
    .sc-manifesto {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 4vw, 3rem);
      border-top: 1px solid var(--sc-rule);
    }

    .sc-manifesto-grid {
      display: grid;
      grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
      gap: clamp(2rem, 5vw, 4rem);
      align-items: start;
    }

    @media (max-width: 860px) {
      .sc-manifesto-grid {
        grid-template-columns: 1fr;
      }
    }

    .sc-statement {
      grid-column: 1 / -1;
      font-family: var(--font-sans);
      font-size: clamp(2.1rem, 5.5vw, 4rem);
      font-weight: 800;
      letter-spacing: -0.045em;
      line-height: 1.04;
      color: var(--sc-ink);
      margin: 1rem 0 2.5rem;
    }

    .sc-manifesto-body p {
      font-size: 1.05rem;
      line-height: 1.75;
      color: var(--sc-mute);
      margin-bottom: 1rem;
      max-width: 60ch;
    }

    .sc-manifesto-body em {
      color: var(--sc-ink);
      font-style: italic;
      font-family: var(--sc-serif);
    }

    .sc-manifesto-aside {
      display: block;
    }

    .sc-aside-block {
      border: 1px solid var(--sc-rule);
      border-radius: 14px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      background: var(--color-surface);
    }

    .sc-aside-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--sc-mute);
    }

    .sc-aside-name {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--sc-ink);
    }

    .sc-aside-foot {
      margin-top: 0.75rem;
      font-size: 0.72rem;
      color: var(--sc-mute);
    }

    /* ── NUMBERS ──────────────────────────────────── */
    .sc-numbers {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 4vw, 3rem);
      border-top: 1px solid var(--sc-rule);
    }

    .sc-stat-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
      margin-top: 2.5rem;
    }

    .sc-numbers motion-stagger {
      display: block;
    }

    .sc-stat-flip {
      display: block;
      width: 100%;
      height: 240px;
      perspective: 1200px;
      cursor: pointer;
    }

    .sc-stat-face {
      width: 100%;
      height: 100%;
      box-sizing: border-box;
      padding: 1.25rem 1.35rem 1.1rem;
      border-radius: 14px;
      border: 1px solid var(--sc-rule);
      background: var(--color-surface);
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      overflow: hidden;
    }

    .sc-stat-face--front {
      position: relative;
    }

    .sc-stat-face--back {
      background: linear-gradient(
        150deg,
        var(--sc-accent),
        color-mix(in srgb, var(--sc-accent) 50%, var(--sc-yellow))
      );
      color: white;
      border-color: transparent;
    }

    .sc-stat-flip-hint {
      margin-top: auto;
      font-size: 0.66rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--sc-mute);
      opacity: 0.85;
    }

    .sc-stat-face--back .sc-stat-tick,
    .sc-stat-tick--inv {
      color: #ffffff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.22);
      opacity: 0.95;
    }

    .sc-stat-back-h {
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.25;
      letter-spacing: -0.01em;
      margin: 0.1rem 0 0.3rem;
      color: white;
    }

    .sc-stat-back-body {
      font-size: 0.78rem;
      line-height: 1.55;
      color: rgba(255, 255, 255, 0.92);
      margin: 0;
    }

    .sc-stat-back-body motion-code-inline {
      color: rgba(255, 255, 255, 0.96);
      background: rgba(0, 0, 0, 0.22);
      padding: 0.1em 0.35em;
      border-radius: 4px;
    }

    .sc-stat-back-list {
      list-style: none;
      margin: 0.2rem 0 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .sc-stat-back-list li {
      display: grid;
      grid-template-columns: 26px 1fr;
      gap: 0.5rem;
      font-size: 0.74rem;
      line-height: 1.4;
      color: rgba(255, 255, 255, 0.93);
    }

    .sc-stat-back-list li span {
      font-weight: 800;
      color: rgba(255, 255, 255, 0.7);
      letter-spacing: 0.04em;
    }

    .sc-stat-back-list li em {
      font-style: italic;
      opacity: 0.78;
    }

    .sc-stat-back-list li strong {
      color: white;
      font-weight: 700;
      text-shadow: none;
    }

    .sc-stat-back-list--row {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.4rem 0.5rem;
    }

    .sc-stat-back-list--row li {
      display: inline-block;
      grid-template-columns: none;
      padding: 0.3rem 0.55rem;
      border: 1px solid rgba(255, 255, 255, 0.35);
      border-radius: 999px;
      font-size: 0.74rem;
      letter-spacing: 0.02em;
    }

    .sc-stat {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      padding: 1.25rem 0;
      border-top: 1px solid var(--sc-rule);
      position: relative;
    }

    .sc-stat-tick {
      font-size: 0.7rem;
      color: var(--sc-accent);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      text-shadow: 0 0 10px var(--sc-glow-magenta);
    }

    .sc-stat strong {
      font-family: var(--font-sans);
      font-size: clamp(2.6rem, 5.5vw, 3.8rem);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1;
      color: var(--sc-ink);
      font-feature-settings: 'tnum';
      text-shadow: 0 0 24px var(--sc-glow-magenta);
    }

    .sc-stat-unit {
      font-size: 0.45em;
      margin-left: 0.15em;
      color: var(--sc-yellow);
      text-shadow: 0 0 12px var(--sc-glow-cyan);
    }

    .sc-stat-cap {
      font-size: 0.78rem;
      color: var(--sc-mute);
      letter-spacing: 0.04em;
    }

    .sc-stat-bar {
      display: block;
      height: 3px;
      width: 100%;
      background: var(--sc-rule);
      margin-top: 0.5rem;
      position: relative;
      overflow: hidden;
    }

    .sc-stat-bar::after {
      content: '';
      position: absolute;
      inset: 0;
      width: var(--bar-w, 100%);
      background: linear-gradient(90deg, var(--sc-accent), var(--sc-yellow));
      box-shadow: 0 0 12px var(--sc-glow-magenta);
      animation: sc-bar-fill 1.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .sc-stat-bar[data-bar='0']::after {
      --bar-w: 0%;
    }
    .sc-stat-bar[data-bar='20']::after {
      --bar-w: 20%;
    }
    .sc-stat-bar[data-bar='100']::after {
      --bar-w: 100%;
    }

    .sc-stat-bar--zero::after {
      background: var(--sc-rule);
      box-shadow: none;
    }

    @keyframes sc-bar-fill {
      from {
        transform: scaleX(0);
        transform-origin: 0 50%;
      }
      to {
        transform: scaleX(1);
        transform-origin: 0 50%;
      }
    }

    /* ── WORDS GRID ───────────────────────────────── */
    .sc-words {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 4vw, 3rem);
      border-top: 1px solid var(--sc-rule);
    }

    .sc-words-head {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .sc-section-h--display {
      font-size: clamp(2.6rem, 7vw, 5.2rem);
      line-height: 0.96;
      letter-spacing: -0.05em;
      max-width: 14ch;
    }

    .sc-italic-block {
      display: inline-block;
      font-family: var(--sc-serif);
      font-style: italic;
      font-weight: 500;
      color: var(--sc-accent);
      letter-spacing: -0.02em;
      transform: rotate(-1.5deg);
      margin: 0 0.15em;
      text-shadow:
        0 0 24px var(--sc-glow-magenta),
        0 0 48px var(--sc-glow-magenta);
    }

    .sc-words-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      grid-auto-rows: minmax(200px, auto);
      gap: 1rem;
    }

    .sc-words-grid motion-tilt {
      display: block;
    }

    .sc-word-card--feature {
      grid-column: span 2;
    }

    @media (max-width: 720px) {
      .sc-word-card--feature {
        grid-column: auto;
      }
    }

    .sc-word-foot {
      display: block;
      margin-top: 0.75rem;
      padding-top: 0.65rem;
      border-top: 1px solid var(--sc-rule);
      font-size: 0.68rem;
      letter-spacing: 0.06em;
      color: var(--sc-mute);
      text-transform: lowercase;
    }

    .sc-word-card {
      display: block;
      border: 1px solid var(--sc-rule);
      border-radius: 16px;
      padding: 1.4rem;
      min-height: 180px;
      background: var(--color-surface);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.04),
        0 0 0 1px rgba(217, 70, 239, 0.04),
        0 12px 40px rgba(0, 0, 0, 0.5);
      transition:
        border-color 0.25s,
        box-shadow 0.25s;
    }

    .sc-word-card:hover {
      border-color: rgba(217, 70, 239, 0.5);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.06),
        0 0 28px rgba(217, 70, 239, 0.18),
        0 12px 40px rgba(0, 0, 0, 0.6);
    }

    .sc-word-tag {
      display: block;
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--sc-accent);
      letter-spacing: 0.04em;
      margin-bottom: 1rem;
      text-shadow: 0 0 10px var(--sc-glow-magenta);
    }

    .sc-word-stage {
      min-height: 80px;
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    .sc-word-text {
      font-size: clamp(1.3rem, 2.4vw, 1.8rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--sc-ink);
      line-height: 1.15;
    }

    .sc-word-hint {
      display: block;
      margin-top: 0.5rem;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--sc-mute);
    }

    /* ── MARQUEE ──────────────────────────────────── */
    .sc-marquee {
      border-top: 1px solid var(--sc-rule);
      border-bottom: 1px solid var(--sc-rule);
      background: var(--color-surface);
      padding: clamp(2.5rem, 6vw, 4rem) 0;
      overflow: hidden;
    }

    .sc-ticker-word {
      font-family: var(--font-sans);
      font-size: clamp(1.6rem, 3.5vw, 2.4rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      color: var(--sc-ink);
      text-shadow: 0 0 24px rgba(217, 70, 239, 0.3);
    }

    .sc-ticker-dot {
      font-size: clamp(1rem, 2vw, 1.4rem);
      color: var(--sc-yellow);
      text-shadow:
        0 0 14px var(--sc-glow-cyan),
        0 0 28px var(--sc-glow-cyan);
    }

    /* ── TOUCH GRID ───────────────────────────────── */
    .sc-touch {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 4vw, 3rem);
    }

    .sc-touch motion-stagger {
      display: block;
    }

    .sc-touch-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1rem;
    }

    .sc-touch-grid motion-tilt {
      display: block;
    }

    .sc-touch-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.6rem 1.5rem 1.75rem;
      border: 1px solid var(--sc-rule);
      border-radius: 18px;
      background: var(--color-surface);
      min-height: 240px;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.04),
        0 0 0 1px rgba(34, 211, 238, 0.04),
        0 12px 40px rgba(0, 0, 0, 0.5);
      transition:
        border-color 0.25s,
        box-shadow 0.25s;
    }

    .sc-touch-card:hover {
      border-color: rgba(34, 211, 238, 0.5);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.06),
        0 0 32px rgba(34, 211, 238, 0.18),
        0 12px 40px rgba(0, 0, 0, 0.6);
    }

    .sc-touch-head {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      margin-bottom: 0.5rem;
    }

    .sc-touch-num {
      font-size: 0.72rem;
      font-weight: 700;
      color: var(--sc-accent);
      letter-spacing: 0.12em;
      padding: 0.2rem 0.45rem;
      border: 1px solid var(--sc-accent);
      border-radius: 4px;
      box-shadow: 0 0 12px var(--sc-glow-magenta);
    }

    .sc-touch-kicker {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--sc-yellow);
      text-shadow: 0 0 8px var(--sc-glow-cyan);
    }

    .sc-touch-rule {
      margin-top: auto;
      height: 2px;
      width: 30%;
      background: linear-gradient(90deg, var(--sc-accent), transparent);
      box-shadow: 0 0 8px var(--sc-glow-magenta);
    }

    .sc-touch-title {
      font-size: 1.45rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.15;
      color: var(--sc-ink);
      margin-bottom: 0.6rem;
    }

    .sc-touch-body {
      font-size: 0.9rem;
      line-height: 1.6;
      color: var(--sc-mute);
      margin: 0;
    }

    /* ── COMPARE ──────────────────────────────────── */
    .sc-compare {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 4vw, 3rem);
      border-top: 1px solid var(--sc-rule);
    }

    .sc-compare-el {
      display: block;
      width: 100%;
      height: clamp(280px, 40vw, 420px);
      border-radius: 18px;
      border: 1px solid var(--sc-rule);
    }

    .sc-compare-pane {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
    }

    .sc-compare-before {
      background:
        radial-gradient(circle at 30% 30%, rgba(34, 211, 238, 0.18) 0%, transparent 60%),
        linear-gradient(135deg, #0a0a14, #1a1a2e);
      color: #22d3ee;
      text-shadow: 0 0 20px rgba(34, 211, 238, 0.6);
    }

    .sc-compare-after {
      background:
        radial-gradient(circle at 70% 70%, rgba(217, 70, 239, 0.3) 0%, transparent 60%),
        linear-gradient(135deg, #4c0a4c, #1a0a2e);
      color: #f0abfc;
      text-shadow: 0 0 24px rgba(217, 70, 239, 0.7);
    }

    .sc-compare-tag {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      opacity: 0.65;
      text-transform: uppercase;
    }

    .sc-compare-label {
      font-size: clamp(2rem, 5vw, 3.4rem);
      font-weight: 800;
      letter-spacing: -0.04em;
    }

    .sc-compare-label--liquid {
      font-family: var(--font-sans);
    }

    .sc-compare-meta {
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      opacity: 0.8;
    }

    /* ── CTA ──────────────────────────────────────── */
    .sc-cta {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 4vw, 3rem);
    }

    .sc-cta-spot {
      display: block;
      border-radius: 24px;
      overflow: hidden;
      isolation: isolate;
    }

    .sc-cta-inner {
      padding: clamp(3rem, 7vw, 5rem) clamp(1.5rem, 4vw, 3rem);
      text-align: center;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(217, 70, 239, 0.18) 0%, transparent 60%),
        radial-gradient(ellipse at 50% 100%, rgba(34, 211, 238, 0.12) 0%, transparent 60%),
        var(--color-surface);
      border: 1px solid var(--sc-rule);
      border-radius: 24px;
      box-shadow:
        inset 0 0 60px rgba(217, 70, 239, 0.06),
        0 0 0 1px rgba(217, 70, 239, 0.08);
    }

    .sc-cta-h {
      font-size: clamp(2.4rem, 6vw, 4.5rem);
      font-weight: 800;
      letter-spacing: -0.045em;
      line-height: 1.04;
      color: var(--sc-ink);
      margin: 1rem 0 1.25rem;
    }

    .sc-cta-liquid {
      display: inline-block;
    }

    .sc-cta-sub {
      font-size: 1.1rem;
      line-height: 1.7;
      color: var(--sc-mute);
      margin: 0 auto 2rem;
      max-width: 50ch;
    }

    .sc-cta-actions {
      display: inline-flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 2rem;
    }

    .sc-cta-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.9rem 1.8rem;
      border-radius: 999px;
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: -0.005em;
      text-decoration: none;
      transition:
        background 0.18s,
        color 0.18s,
        border-color 0.18s;
    }

    .sc-cta-btn--primary {
      background: var(--sc-accent);
      color: #07070d;
      box-shadow:
        0 0 20px var(--sc-glow-magenta),
        0 0 40px rgba(217, 70, 239, 0.25);
      transition:
        box-shadow 0.25s,
        transform 0.18s;
    }

    .sc-cta-btn--primary:hover {
      box-shadow:
        0 0 28px var(--sc-glow-magenta),
        0 0 56px rgba(217, 70, 239, 0.45);
      text-decoration: none;
    }

    .sc-cta-btn--ghost {
      border: 1px solid var(--sc-yellow);
      color: var(--sc-yellow);
      background: transparent;
      box-shadow: 0 0 18px rgba(34, 211, 238, 0.18);
      transition:
        box-shadow 0.25s,
        color 0.18s;
    }

    .sc-cta-btn--ghost:hover {
      color: #07070d;
      background: var(--sc-yellow);
      box-shadow:
        0 0 24px var(--sc-glow-cyan),
        0 0 48px rgba(34, 211, 238, 0.35);
      text-decoration: none;
    }

    .sc-cta-foot {
      font-size: 0.85rem;
      color: var(--sc-mute);
      margin: 0;
    }

    .sc-cta-foot code {
      font-size: 1em;
      color: var(--sc-accent);
      background: color-mix(in srgb, var(--sc-accent) 10%, transparent);
      padding: 0.25em 0.6em;
      border-radius: 6px;
    }

    /* ── motion-code showcase section ──────────── */
    .sc-codeshow {
      max-width: 1280px;
      margin: 0 auto;
      padding: clamp(4rem, 10vw, 8rem) clamp(1.25rem, 4vw, 3rem);
      border-top: 1px solid var(--sc-rule);
      position: relative;
    }

    .sc-codeshow > *:not(.sc-codeshow-bg) {
      position: relative;
      z-index: 1;
    }

    .sc-codeshow-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: 0;
    }

    .sc-codeshow-bg motion-parallax {
      display: block;
      position: absolute;
    }

    .sc-shape--cs1 {
      width: 160px;
      height: 160px;
      top: 4%;
      left: -50px;
      opacity: 0.28;
    }

    .sc-shape--cs2 {
      width: 110px;
      height: 110px;
      bottom: 6%;
      right: -30px;
      opacity: 0.3;
    }

    .sc-codeshow-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
      margin-top: 3rem;
    }

    @media (max-width: 760px) {
      .sc-codeshow-grid {
        grid-template-columns: 1fr;
      }
    }

    .sc-codeshow-card {
      display: block;
      /* Grid items default to min-width:auto, so the code window's long
         (non-wrapping) lines force the track wider than the viewport and the
         card overflows the screen on mobile. min-width:0 lets the track shrink
         and the code scroll inside its own box instead. */
      min-width: 0;
      padding: 1.25rem;
      border: 1px solid var(--sc-rule);
      border-radius: 14px;
      background: var(--color-surface);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.04),
        0 12px 36px rgba(0, 0, 0, 0.05);
    }

    .sc-codeshow-grid motion-code[type] {
      min-height: 17rem;
    }

    .sc-codeshow-card--span {
      grid-column: span 2;
    }

    @media (max-width: 760px) {
      .sc-codeshow-card--span {
        grid-column: auto;
      }
    }

    .sc-codeshow-head {
      display: flex;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      padding-bottom: 0.7rem;
      margin-bottom: 0.8rem;
      border-bottom: 1px solid var(--sc-rule);
    }

    .sc-codeshow-num {
      padding: 0.2rem 0.55rem;
      border: 1px solid var(--sc-accent);
      border-radius: 4px;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      color: var(--sc-accent);
      box-shadow: 0 0 14px var(--sc-glow-magenta);
    }

    .sc-codeshow-label {
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--sc-yellow);
      text-shadow: 0 0 10px var(--sc-glow-cyan);
      flex-grow: 1;
    }

    .sc-codeshow-meta {
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      color: var(--sc-mute);
      text-transform: lowercase;
    }

    /* ── inline-mode block (N° 04) ────────────── */
    .sc-codeshow-inline {
      display: block;
      margin-top: 1.25rem;
      padding: 1.5rem 1.5rem 1.75rem;
      border: 1px solid var(--sc-rule);
      border-radius: 14px;
      background: var(--color-surface);
    }

    .sc-codeshow-prose {
      font-size: 0.95rem;
      line-height: 1.75;
      color: var(--sc-ink);
      margin: 0 0 0.85rem;
      max-width: 64ch;
    }

    .sc-codeshow-prose:last-of-type {
      margin-bottom: 1.25rem;
    }

    .sc-codeshow-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      padding-top: 1rem;
      border-top: 1px dotted var(--sc-rule);
    }

    /* ── recipe blocks ─────────────────────────── */
    .sc-recipe {
      display: block;
      margin-top: 3rem;
      grid-column: 1 / -1;
    }

    .sc-recipe--inline {
      margin-top: 2.5rem;
      margin-bottom: 0.5rem;
    }

    .sc-recipe-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      padding: 0 0 0.65rem 0.25rem;
      margin-bottom: 0.4rem;
      border-bottom: 1px solid var(--sc-rule);
    }

    .sc-recipe-head--centered {
      justify-content: center;
      gap: 0.6rem 1.2rem;
    }

    .sc-recipe-label {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--sc-accent);
      text-shadow: 0 0 12px var(--sc-glow-magenta);
    }

    .sc-recipe-meta {
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      color: var(--sc-mute);
      text-transform: lowercase;
    }

    .sc-cta-recipe {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      max-width: 580px;
      margin: 0 auto;
      text-align: left;
    }

    @media (max-width: 640px) {
      .sc-hero-orn {
        position: static;
        margin-bottom: 1rem;
      }
    }

    /* ── cover plate metadata band ──────────────── */
    .sc-cover-band {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.5rem;
      padding: 0.85rem 0;
      margin-bottom: 2rem;
      border-top: 1px solid var(--sc-rule);
      border-bottom: 1px solid var(--sc-rule);
    }

    .sc-cover-band-item {
      display: inline-flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .sc-cover-band-key {
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--sc-mute);
    }

    .sc-cover-band-val {
      font-size: 0.86rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--sc-ink);
    }

    /* ── inside-this-issue contents block ──────── */
    .sc-cover-foot {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: clamp(2rem, 5vw, 4rem);
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--sc-rule);
      align-items: start;
    }

    @media (max-width: 760px) {
      .sc-cover-foot {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }
    }

    .sc-cover-toc {
      display: block;
      max-width: 480px;
    }

    .sc-cover-countdown {
      display: block;
      padding: 1.4rem 1.5rem;
      border: 1px solid var(--sc-rule);
      border-radius: 14px;
      background: var(--color-surface);
    }

    .sc-countdown-stage {
      display: flex;
      justify-content: flex-start;
      margin-top: 0.85rem;
    }

    .sc-cover-countdown motion-countdown {
      --countdown-color: var(--sc-ink);
      --countdown-label-color: var(--sc-mute);
      --countdown-size: clamp(1.5rem, 2.8vw, 2rem);
      --countdown-label-size: 0.6rem;
      --countdown-gap: 0.7rem;
    }

    .sc-countdown-cap {
      font-size: 0.95rem;
      line-height: 1.45;
      color: var(--sc-ink);
      margin: 0;
      font-weight: 600;
      letter-spacing: -0.005em;
    }

    .sc-countdown-foot {
      margin: 0.85rem 0 0;
      padding-top: 0.75rem;
      border-top: 1px solid var(--sc-rule);
      font-size: 0.74rem;
      letter-spacing: 0.08em;
      text-transform: lowercase;
      color: var(--sc-mute);
    }

    .sc-toc-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--sc-accent);
      text-shadow: 0 0 12px var(--sc-glow-magenta);
      margin: 0 0 0.85rem;
    }

    .sc-toc-list {
      list-style: none;
      margin: 0;
      padding: 0;
      counter-reset: toc;
    }

    .sc-toc-list li {
      display: grid;
      grid-template-columns: 2.5rem 1fr;
      gap: 0.6rem;
      padding: 0.55rem 0;
      border-bottom: 1px dotted var(--sc-rule);
      font-size: 0.95rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      color: var(--sc-ink);
    }

    .sc-toc-list li span {
      font-weight: 700;
      color: var(--sc-yellow);
      text-shadow: 0 0 10px var(--sc-glow-cyan);
      letter-spacing: 0.02em;
    }

    /* ── closing colophon strip ────────────────── */
    .sc-colophon {
      border-top: 1px solid var(--sc-rule);
      background: var(--color-surface);
      padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 4vw, 3rem);
      position: relative;
      z-index: 1;
    }

    .sc-colophon-inner {
      max-width: 1280px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 130px minmax(0, 1.8fr) minmax(0, 1fr);
      gap: clamp(2rem, 4vw, 3.5rem);
      align-items: start;
    }

    @media (max-width: 760px) {
      .sc-colophon-inner {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    .sc-colophon-mark {
      width: 130px;
      height: 130px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .sc-colophon-dot {
      font-size: 1.2rem;
      color: var(--sc-yellow);
      text-shadow:
        0 0 14px var(--sc-glow-cyan),
        0 0 28px var(--sc-glow-cyan);
    }

    .sc-colophon-eyebrow {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--sc-accent);
      text-shadow: 0 0 12px var(--sc-glow-magenta);
      margin: 0 0 1rem;
    }

    .sc-colophon-text {
      font-size: 0.95rem;
      line-height: 1.7;
      color: var(--sc-mute);
      margin: 0 0 0.85rem;
      max-width: 56ch;
    }

    .sc-colophon-text--small {
      font-size: 0.82rem;
      color: var(--sc-mute);
      opacity: 0.8;
    }

    .sc-colophon-text em {
      font-family: var(--sc-serif);
      font-style: italic;
      color: var(--sc-ink);
    }

    .sc-colophon-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem 1rem;
      align-self: end;
      padding: 1rem 0;
      border-top: 1px solid var(--sc-rule);
    }

    .sc-colophon-pair {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .sc-colophon-pair span {
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--sc-mute);
    }

    .sc-colophon-pair strong {
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--sc-ink);
      text-shadow: 0 0 14px var(--sc-glow-magenta);
      font-feature-settings: 'tnum';
    }
  </style>
</Layout>
