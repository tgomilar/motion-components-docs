---
import Layout from '../../layouts/Layout.astro'
import CodeWindow from '../../components/CodeWindow.astro'
---

<Layout
  title="Showcase — Motion Components"
  description="An editorial showcase of motion-components in real composition. Physics-based motion, framework-agnostic, drop-in.">
  <main class="sc">
    <!-- ── COVER PLATE ─────────────────────────────────── -->
    <motion-spotlight
      class="sc-hero-spot"
      size="900"
      color="rgba(192,38,211,0.22)"
      smoothing="0.08">
      <section class="sc-hero">
        <!-- thin parallax line, no orbs -->
        <div class="sc-hero-bg" aria-hidden="true">
          <motion-parallax speed="0.15" axis="x"><div class="sc-grid-line"></div></motion-parallax>
        </div>

        <!-- printer's ornament -->
        <div class="sc-hero-orn" aria-hidden="true">
          <motion-magnetic distance="160" strength="0.45">
            <span class="sc-orn">
              <motion-circle text="MOTION SPECIMEN · 2026 ED. · " radius="62" speed="14"
                ><span class="sc-orn-dot">✦</span></motion-circle
              >
            </span>
          </motion-magnetic>
        </div>

        <!-- top metadata band: edition + run + date -->
        <div class="sc-cover-band">
          <motion-reveal duration="0.7" y="14">
            <span class="sc-cover-band-item">
              <span class="sc-cover-band-key">Edition</span>
              <span class="sc-cover-band-val">N°01</span>
            </span>
          </motion-reveal>
          <motion-reveal duration="0.7" y="14">
            <span class="sc-cover-band-item">
              <span class="sc-cover-band-key">Run</span>
              <span class="sc-cover-band-val">∞ / unlimited</span>
            </span>
          </motion-reveal>
          <motion-reveal duration="0.7" y="14">
            <span class="sc-cover-band-item">
              <span class="sc-cover-band-key">Pressed</span>
              <span class="sc-cover-band-val">2026 · MIT</span>
            </span>
          </motion-reveal>
          <motion-reveal duration="0.7" y="14">
            <span class="sc-cover-band-item">
              <span class="sc-cover-band-key">Format</span>
              <span class="sc-cover-band-val">Web Components</span>
            </span>
          </motion-reveal>
        </div>

        <motion-reveal duration="0.7" y="18">
          <p class="sc-eyebrow">
            <motion-typewriter speed="40" cursor
              >A specimen book for motion in interface design</motion-typewriter
            >
          </p>
        </motion-reveal>

        <h1 class="sc-h1">
          <motion-parallax speed="0.9" axis="x">
            <motion-split by="words" interval="0.08" duration="0.85" y="34"
              >An interface</motion-split
            >
          </motion-parallax>
          <motion-parallax speed="0.7" axis="x">
            <motion-split by="words" interval="0.08" duration="0.85" y="34" class="sc-h1-italic"
              >that breathes,</motion-split
            >
          </motion-parallax>
          <motion-parallax speed="0.5" axis="x">
            <motion-split by="words" interval="0.08" duration="0.85" y="34"
              >overshoots,</motion-split
            >
          </motion-parallax>
          <motion-parallax speed="0.3" axis="x">
            <motion-split by="words" interval="0.08" duration="0.85" y="34" class="sc-h1-and"
              >and settles.</motion-split
            >
          </motion-parallax>
        </h1>

        <!-- subtitle -->
        <motion-reveal duration="0.85" y="20" class="sc-hero-sub">
          <p>
            Six plates. Thirty-three components. A library of physics-based motion — pressed,
            paginated, and presented like the artefact it is.
            <motion-scramble class="sc-hero-scramble"
              >Spring physics. Drop-in. Framework-agnostic.</motion-scramble
            >
          </p>
        </motion-reveal>

        <motion-reveal duration="0.85" y="14" class="sc-hero-meta">
          <div class="sc-meta-row">
            <span class="sc-meta-tag">Framework-agnostic</span>
            <span class="sc-meta-dot">·</span>
            <span class="sc-meta-tag">Spring physics</span>
            <span class="sc-meta-dot">·</span>
            <span class="sc-meta-tag">~20 KB brotlied</span>
            <span class="sc-meta-dot">·</span>
            <span class="sc-meta-tag">Tree-shakeable</span>
          </div>
        </motion-reveal>

        <motion-reveal duration="0.85" y="14">
          <div class="sc-hero-cycler" aria-hidden="true">
            <span class="sc-cycler-prefix">Featured this issue</span>
            <motion-words
              words="hero plates, marquees, scroll-revealed type, magnetic ornaments, before-and-after cuts, cover-spread parallax"
              colors="#c026d3, #0891b2, #65a30d, #db2777, #2563eb, #f59e0b"
              interval="2400"
              duration="0.7"
              class="sc-cycler-word"></motion-words>
          </div>
        </motion-reveal>

        <!-- bottom-of-cover: index + countdown -->
        <div class="sc-cover-foot">
          <motion-reveal duration="0.85" y="22" class="sc-cover-toc">
            <p class="sc-toc-label">Inside this issue</p>
            <ol class="sc-toc-list">
              <motion-stagger interval="0.09" duration="0.65" y="18">
                <li
                  ><motion-parallax speed="0.85" axis="x"><span>I.</span></motion-parallax> Lab Note ·
                  the thesis</li
                >
                <li
                  ><motion-parallax speed="0.7" axis="x"><span>II.</span></motion-parallax> Telemetry
                  · the receipts</li
                >
                <li
                  ><motion-parallax speed="0.55" axis="x"><span>III.</span></motion-parallax> Type Foundry
                  · six specimens</li
                >
                <li
                  ><motion-parallax speed="0.4" axis="x"><span>IV.</span></motion-parallax> Doctrines
                  · six rules</li
                >
                <li
                  ><motion-parallax speed="0.25" axis="x"><span>V.</span></motion-parallax> Cuts &amp;
                  Springs · the slider</li
                >
                <li
                  ><motion-parallax speed="0.1" axis="x"><span>VI.</span></motion-parallax> Colophon ·
                  how to acquire</li
                >
              </motion-stagger>
            </ol>
          </motion-reveal>

          <motion-reveal duration="0.85" y="22" class="sc-cover-countdown">
            <p class="sc-toc-label">Issue N°02 · pressing</p>
            <p class="sc-countdown-cap">The next specimen drops in</p>
            <div class="sc-countdown-stage">
              <motion-countdown to="2027-01-01T00:00:00" format="days hours minutes seconds" labels
              ></motion-countdown>
            </div>
            <p class="sc-countdown-foot">— typeset, prepped, &amp; spring-tuned</p>
          </motion-reveal>
        </div>
      </section>
    </motion-spotlight>

    <!-- ── MANIFESTO ──────────────────────────────────── -->
    <section class="sc-manifesto">
      <div class="sc-manifesto-bg" aria-hidden="true">
        <motion-parallax speed="0.4" axis="y"
          ><div class="sc-blob sc-blob--magenta"></div></motion-parallax
        >
        <motion-parallax speed="0.7" axis="y"
          ><div class="sc-blob sc-blob--cyan"></div></motion-parallax
        >
      </div>

      <div class="sc-manifesto-grid">
        <motion-reveal duration="0.7" y="14">
          <p class="sc-chapter">
            <span class="sc-chapter-num">PLATE 01 / 06</span>
            <span class="sc-chapter-name">— Lab Note</span>
          </p>
        </motion-reveal>

        <motion-headline by="words" interval="0.07" duration="1" class="sc-statement">
          Motion is not decoration.
        </motion-headline>

        <div class="sc-manifesto-body">
          <motion-reveal duration="0.85" y="22">
            <p>
              Hard cuts teach the brain that this world has no physics. Springs teach it the
              opposite — every shift carries velocity from one state into the next, and an
              interrupted motion <em>continues</em> rather than snaps.
            </p>
          </motion-reveal>

          <motion-reveal duration="0.85" y="22">
            <p>
              Every motion you see is a tag inside a tag. No render functions. No animation library
              to wire up. No adapters per framework.
              <motion-words
                words="composed, declarative, framework-free, on demand"
                colors="#c026d3, #0891b2, #65a30d, #db2777"
                interval="2200"
                duration="0.55"
                class="sc-inline-word"></motion-words>. Compose once. Tune later.
            </p>
          </motion-reveal>
        </div>

        <motion-parallax speed="0.4" class="sc-manifesto-aside" aria-hidden="true">
          <div class="sc-aside-block">
            <span class="sc-aside-label">Built on</span>
            <span class="sc-aside-name">
              <motion-typewriter speed="50" loop cursor>Motion One</motion-typewriter>
            </span>
            <span class="sc-aside-name sc-aside-name--small">+ Lit</span>
            <span class="sc-aside-foot">native custom elements</span>
          </div>
        </motion-parallax>
      </div>
    </section>

    <!-- ── ARC DIVIDER ───────────────────────────────── -->
    <div class="sc-arc-divider">
      <motion-reveal duration="0.85" y="22" class="sc-arc-features">
        <p class="sc-arc-eyebrow">Featured this issue</p>
        <ul class="sc-arc-list">
          <motion-stagger interval="0.1" duration="0.6" y="14">
            <li>
              <a href="/docs/scroll/motion-parallax/" class="sc-arc-link">
                <motion-code-inline copy>motion-parallax</motion-code-inline>
                <span class="sc-arc-link-arrow" aria-hidden="true">↗</span>
              </a>
              <span class="sc-arc-link-cap">
                scroll-driven drift · the orbiting numerals on the cover
                <a href="/showcase/parallax/" class="sc-arc-showcase">see the showcase ↗</a>
              </span>
            </li>

            <li>
              <a href="/docs/scroll/motion-scene/" class="sc-arc-link">
                <motion-code-inline copy>motion-scene</motion-code-inline>
                <span class="sc-arc-link-arrow" aria-hidden="true">↗</span>
              </a>
              <span class="sc-arc-link-cap">
                scroll-anchored choreography · pin a stage, sequence the moves
                <a href="/showcase/scene/" class="sc-arc-showcase">see the showcase ↗</a>
              </span>
            </li>

            <li>
              <a href="/docs/text/motion-font/" class="sc-arc-link">
                <motion-code-inline copy>motion-font</motion-code-inline>
                <span class="sc-arc-link-arrow" aria-hidden="true">↗</span>
              </a>
              <span class="sc-arc-link-cap">
                variable-font axis tweens · weight, slant, optical size — all springy
                <a href="/showcase/motion-font/" class="sc-arc-showcase">see the showcase ↗</a>
              </span>
            </li>
          </motion-stagger>
        </ul>
      </motion-reveal>

      <div class="sc-arc-orn" aria-hidden="true">
        <motion-arc
          text="SPECIMENS · OF · MOTION · IN · 33 · TAGS · ✦ · "
          radius="180"
          speed="6"
          class="sc-arc"></motion-arc>
      </div>
    </div>

    <!-- ── SPECIMEN 02 · NUMBERS AS BROADCAST ─────────── -->
    <section class="sc-numbers">
      <div class="sc-numbers-bg" aria-hidden="true">
        <motion-parallax speed="0.6"><div class="sc-grid-fade"></div></motion-parallax>
      </div>

      <motion-reveal duration="0.7" y="14">
        <p class="sc-chapter">
          <span class="sc-chapter-num">PLATE 02 / 06</span>
          <span class="sc-chapter-name">— Telemetry</span>
        </p>
      </motion-reveal>
      <h2 class="sc-section-h">
        <motion-headline by="words" interval="0.07" duration="1">Read the dials.</motion-headline>
      </h2>
      <motion-reveal duration="0.85" y="22"
        ><p class="sc-section-sub"
          >A live receipt — not a sales sheet. Numbers that move because the page just loaded them.</p
        ></motion-reveal
      >

      <motion-stagger interval="0.12" duration="0.7" y="32">
        <div class="sc-stat-row">
          <motion-flip-card
            trigger="hover"
            axis="y"
            duration="0.85"
            bounce="0.25"
            class="sc-stat-flip">
            <div slot="front" class="sc-stat-face sc-stat-face--front">
              <span class="sc-stat-tick">N° 01</span>
              <strong><motion-counter from="0" to="33" duration="1.8"></motion-counter></strong>
              <span class="sc-stat-cap">composable components</span>
              <span class="sc-stat-bar" data-bar="100"></span>
              <span class="sc-stat-flip-hint">hover for the breakdown ↺</span>
            </div>
            <div slot="back" class="sc-stat-face sc-stat-face--back">
              <span class="sc-stat-tick sc-stat-tick--inv">N° 01 — composition</span>
              <p class="sc-stat-back-h">Five families. All composable.</p>
              <ul class="sc-stat-back-list">
                <li><span>08</span> Primitives — hover, press, tilt…</li>
                <li><span>16</span> Text — split, glitch, ticker…</li>
                <li><span>07</span> Interaction — slider, gallery, flip-card…</li>
                <li><span>02</span> Scroll — parallax, scene</li>
              </ul>
            </div>
          </motion-flip-card>

          <motion-flip-card
            trigger="hover"
            axis="y"
            duration="0.85"
            bounce="0.25"
            class="sc-stat-flip">
            <div slot="front" class="sc-stat-face sc-stat-face--front">
              <span class="sc-stat-tick">N° 02</span>
              <strong
                >~<motion-counter from="0" to="20" duration="1.8"></motion-counter><span
                  class="sc-stat-unit">KB</span
                ></strong
              >
              <span class="sc-stat-cap">brotlied, full bundle</span>
              <span class="sc-stat-bar" data-bar="20"></span>
              <span class="sc-stat-flip-hint">hover for the bundle math ↺</span>
            </div>
            <div slot="back" class="sc-stat-face sc-stat-face--back">
              <span class="sc-stat-tick sc-stat-tick--inv">N° 02 — pay only for what you use</span>
              <p class="sc-stat-back-h">Each tag is its own subpath export.</p>
              <p class="sc-stat-back-body">
                The full bundle is convenient. <motion-code-inline copy
                  >import 'motion-components/motion-headline'</motion-code-inline
                > drops to the cost of just that one tag — bundlers tree-shake the rest.
              </p>
            </div>
          </motion-flip-card>

          <motion-flip-card
            trigger="hover"
            axis="y"
            duration="0.85"
            bounce="0.25"
            class="sc-stat-flip">
            <div slot="front" class="sc-stat-face sc-stat-face--front">
              <span class="sc-stat-tick">N° 03</span>
              <strong><motion-counter from="0" to="0" duration="0.5"></motion-counter></strong>
              <span class="sc-stat-cap">framework lock-in</span>
              <span class="sc-stat-bar sc-stat-bar--zero" data-bar="0"></span>
              <span class="sc-stat-flip-hint">hover for the runtimes ↺</span>
            </div>
            <div slot="back" class="sc-stat-face sc-stat-face--back">
              <span class="sc-stat-tick sc-stat-tick--inv">N° 03 — same HTML, every framework</span>
              <p class="sc-stat-back-h">The browser is the runtime.</p>
              <ul class="sc-stat-back-list sc-stat-back-list--row">
                <li>React 19+</li><li>Vue 3</li><li>Svelte</li><li>SolidJS</li><li>Astro</li><li
                  >Angular</li
                ><li>Alpine</li><li>plain HTML</li>
              </ul>
            </div>
          </motion-flip-card>
        </div>
      </motion-stagger>
    </section>

    <!-- ── SPECIMEN 03 · TYPE THAT MOVES ITSELF ───────── -->
    <section class="sc-words">
      <div class="sc-words-bg" aria-hidden="true">
        <motion-parallax speed="0.25" axis="y"
          ><div class="sc-shape sc-shape--diamond"></div></motion-parallax
        >
        <motion-parallax speed="0.5" axis="y"
          ><div class="sc-shape sc-shape--ring"></div></motion-parallax
        >
      </div>

      <motion-reveal duration="0.7" y="14">
        <p class="sc-chapter">
          <span class="sc-chapter-num">PLATE 03 / 06</span>
          <span class="sc-chapter-name">— Type Foundry</span>
        </p>
      </motion-reveal>

      <div class="sc-words-head">
        <h2 class="sc-section-h sc-section-h--display">
          Type
          <span class="sc-italic-block">that types</span>
          itself.
        </h2>
        <motion-reveal duration="0.85" y="22">
          <p class="sc-section-sub">
            Six specimens. Every one auto-animates on its own clock — staggered intervals so the
            page never feels metronomic. Spring physics through Motion One; no CSS keyframes; no
            setInterval that you write.
          </p>
        </motion-reveal>
      </div>

      <motion-stagger interval="0.08" duration="0.65" y="24">
        <div class="sc-words-grid">
          <motion-tilt max="6" scale="1.02">
            <motion-spotlight
              class="sc-word-card sc-word-card--feature"
              color="rgba(192,38,211,0.35)">
              <span class="sc-word-tag">specimen no. 1 · motion-typewriter</span>
              <div class="sc-word-stage">
                <motion-typewriter speed="55" loop cursor class="sc-word-text"
                  >type. pause. resume.</motion-typewriter
                >
              </div>
              <span class="sc-word-foot">loops · 55 cps · keyboard cursor</span>
            </motion-spotlight>
          </motion-tilt>

          <motion-tilt max="6" scale="1.02">
            <motion-spotlight class="sc-word-card" color="rgba(8,145,178,0.32)">
              <span class="sc-word-tag">specimen no. 2 · motion-scramble</span>
              <div class="sc-word-stage">
                <motion-scramble id="sc-loop-scramble" class="sc-word-text"
                  >decode the future</motion-scramble
                >
              </div>
              <span class="sc-word-foot">cypher reveal · auto-loops</span>
            </motion-spotlight>
          </motion-tilt>

          <motion-tilt max="6" scale="1.02">
            <motion-spotlight class="sc-word-card" color="rgba(101,163,13,0.30)">
              <span class="sc-word-tag">specimen no. 3 · motion-glitch</span>
              <div class="sc-word-stage">
                <motion-glitch class="sc-word-text" loop>SYSTEM ONLINE</motion-glitch>
              </div>
              <span class="sc-word-foot">channel decay · 1.4s loop</span>
            </motion-spotlight>
          </motion-tilt>

          <motion-tilt max="6" scale="1.02">
            <motion-spotlight
              class="sc-word-card sc-word-card--feature"
              color="rgba(168,85,247,0.32)">
              <span class="sc-word-tag">specimen no. 4 · motion-words</span>
              <div class="sc-word-stage">
                <motion-words
                  words="loud, quiet, fast, slow, calm, sharp, soft, alive"
                  colors="#c026d3, #0891b2, #65a30d, #f472b6, #2563eb, #fb7185, #c084fc, #f59e0b"
                  interval="1500"
                  duration="0.6"
                  class="sc-word-text"></motion-words>
              </div>
              <span class="sc-word-foot">8 states · 1.5s cadence · per-word color</span>
            </motion-spotlight>
          </motion-tilt>

          <motion-tilt max="6" scale="1.02">
            <motion-spotlight class="sc-word-card" color="rgba(244,114,182,0.30)">
              <span class="sc-word-tag">specimen no. 5 · motion-counter</span>
              <div class="sc-word-stage">
                <motion-counter
                  id="sc-loop-counter"
                  from="0"
                  to="2026"
                  duration="2.1"
                  class="sc-word-text"></motion-counter>
              </div>
              <span class="sc-word-foot">spring-eased numerals · auto-loops</span>
            </motion-spotlight>
          </motion-tilt>

          <motion-tilt max="6" scale="1.02">
            <motion-spotlight class="sc-word-card" color="rgba(56,189,248,0.30)">
              <span class="sc-word-tag">specimen no. 6 · motion-headline</span>
              <div class="sc-word-stage">
                <motion-headline
                  id="sc-loop-headline"
                  by="chars"
                  variant="flip"
                  interval="0.05"
                  duration="0.85"
                  class="sc-word-text">FLIP &amp; SETTLE</motion-headline
                >
              </div>
              <span class="sc-word-foot">char flip · spring · auto-loops</span>
            </motion-spotlight>
          </motion-tilt>
        </div>
      </motion-stagger>
    </section>

    <!-- ── CURVE WAVE BREAK ─────────────────────────── -->
    <div class="sc-curve-break" aria-hidden="true">
      <motion-curve
        text="✦  composed not styled-in  ✦  drop in any framework  ✦  springs over curves  ✦  composition over config  "
        loop
        loop-speed="50"
        amplitude="14"
        wave-length="380"
        speed="0.18"
        loop-gap="0"
        class="sc-curve"></motion-curve>
    </div>

    <!-- ── TICKER WAVE ────────────────────────────────── -->
    <section class="sc-marquee">
      <motion-ticker
        speed="55"
        gap="40"
        wave
        wave-amplitude="12"
        wave-length="380"
        pause-on-hover="false"
        class="sc-ticker">
        <span class="sc-ticker-word">Spring physics</span>
        <span class="sc-ticker-dot">✦</span>
        <span class="sc-ticker-word">Drop in. Compose.</span>
        <span class="sc-ticker-dot">✦</span>
        <span class="sc-ticker-word">No janky cuts</span>
        <span class="sc-ticker-dot">✦</span>
        <span class="sc-ticker-word">Reduced-motion aware</span>
        <span class="sc-ticker-dot">✦</span>
        <span class="sc-ticker-word">Tree-shake from one tag</span>
        <span class="sc-ticker-dot">✦</span>
        <span class="sc-ticker-word">Web Components standard</span>
        <span class="sc-ticker-dot">✦</span>
      </motion-ticker>
    </section>

    <!-- ── SPECIMEN 04 · DOCTRINES ────────────────────── -->
    <section class="sc-touch">
      <div class="sc-touch-bg" aria-hidden="true">
        <motion-parallax speed="0.2" axis="y"
          ><div class="sc-shape sc-shape--square"></div></motion-parallax
        >
        <motion-parallax speed="0.45" axis="y"
          ><div class="sc-shape sc-shape--bar"></div></motion-parallax
        >
      </div>

      <motion-reveal duration="0.7" y="14">
        <p class="sc-chapter">
          <span class="sc-chapter-num">PLATE 04 / 06</span>
          <span class="sc-chapter-name">— Doctrines</span>
        </p>
      </motion-reveal>
      <h2 class="sc-section-h">
        <motion-headline by="words" interval="0.07" duration="1"
          >Six rules. No compromises.</motion-headline
        >
      </h2>
      <motion-reveal duration="0.85" y="22">
        <p class="sc-section-sub">
          Each tile is its own composition: <motion-code-inline copy>motion-tilt</motion-code-inline
          > wrapping <motion-code-inline copy>motion-spotlight</motion-code-inline>. Cursor-tracked
          light, physics-driven 3D — two primitives, six surfaces.
        </p>
      </motion-reveal>

      <motion-stagger interval="0.08" duration="0.65" y="24">
        <div class="sc-touch-grid">
          {
            [
              {
                num: '01',
                title: 'Springs over curves',
                kicker: 'Easing',
                body: 'Cubic-bezier snaps. Springs flow. Interrupt one mid-flight and it carries velocity into the next state.',
              },
              {
                num: '02',
                title: 'Composition over config',
                kicker: 'Architecture',
                body: 'Wrap a tag inside another tag. No props bridges. No render functions. No adapters.',
              },
              {
                num: '03',
                title: 'Standards over abstractions',
                kicker: 'Foundation',
