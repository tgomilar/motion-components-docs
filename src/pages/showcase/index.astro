  <script>
    import 'motion-components'

    type Replayable = HTMLElement & { replay?: () => void }

    function loopReplay(id: string, intervalMs: number, initialDelay = 0) {
      const el = document.getElementById(id) as Replayable | null
      if (!el) return
      const tick = () => {
        if (typeof el.replay === 'function') el.replay()
      }
      window.setTimeout(() => {
        tick()
        window.setInterval(tick, intervalMs)
      }, initialDelay)
    }

    // wait for custom elements + first paint, then loop the non-auto effects
    customElements
      .whenDefined('motion-scramble')
      .then(() => loopReplay('sc-loop-scramble', 3200, 1500))
    customElements
      .whenDefined('motion-counter')
      .then(() => loopReplay('sc-loop-counter', 3600, 2500))
    customElements
      .whenDefined('motion-headline')
      .then(() => loopReplay('sc-loop-headline', 4200, 2000))
  </script>

