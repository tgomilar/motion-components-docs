---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Scroll Story — motion-scene Showcase" noMain>
  <div class="showcase">

    <!-- ── Intro ──────────────────────────────────────────── -->
    <section class="intro">
      <p class="intro-eyebrow">motion-scene</p>
      <h1 class="intro-title">Scroll<br/>Stories</h1>
      <p class="intro-body">
        Three scenes. Three techniques.<br/>One scroll. Zero JavaScript.
      </p>
      <div class="intro-hint" aria-hidden="true">↓</div>
    </section>

    <!-- ── Scene 01 — DECLARE (slides from above) ─────────── -->
    <motion-scene height="220vh" class="scene">
      <div class="s1-body">

        <span
          class="s1-index"
          data-from='{"opacity":0,"y":"-28px"}'
          data-to='{"opacity":1,"y":"0px"}'
          data-start="0.0"
          data-end="0.2"
        >001</span>

        <h2
          class="s1-title"
          data-from='{"opacity":0,"y":"-55px"}'
          data-to='{"opacity":1,"y":"0px"}'
          data-start="0.1"
          data-end="0.35"
        >DECLARE</h2>

        <p
          class="s1-desc"
          data-from='{"opacity":0,"y":"-22px"}'
          data-to='{"opacity":1,"y":"0px"}'
          data-start="0.28"
          data-end="0.5"
        >Animations live directly in HTML as data attributes —<br/>readable, portable, no build step.</p>

        <div
          class="s1-code"
          data-from='{"opacity":0,"y":"-18px"}'
          data-to='{"opacity":1,"y":"0px"}'
          data-start="0.44"
          data-end="0.68"
        >
          <span class="c-muted">data-from=</span><span class="c-str">'&#123;"opacity":0,"y":"-40px"&#125;'</span><br/>
          <span class="c-muted">data-to=</span><span class="c-str">'&#123;"opacity":1,"y":"0px"&#125;'</span><br/>
          <span class="c-muted">data-start=</span><span class="c-num">"0.1"</span>
          <span class="c-muted"> data-end=</span><span class="c-num">"0.5"</span>
        </div>

        <div
          class="s1-tech"
          data-from='{"opacity":0,"y":"-12px"}'
          data-to='{"opacity":0.5,"y":"0px"}'
          data-start="0.6"
          data-end="0.78"
        >technique: y + opacity</div>

      </div>
    </motion-scene>

    <!-- ── Scene 02 — ANIMATE (scale + x translations) ────── -->
    <motion-scene height="220vh" class="scene">
      <div class="s2-body">

        <span
          class="s2-index"
          data-from='{"opacity":0,"x":"40px"}'
          data-to='{"opacity":1,"x":"0px"}'
          data-start="0.0"
          data-end="0.2"
        >002</span>

        <h2
          class="s2-title"
          data-from='{"opacity":0,"scale":"0.78"}'
          data-to='{"opacity":1,"scale":"1"}'
          data-start="0.1"
          data-end="0.38"
        >ANIMATE</h2>

        <div
          class="s2-grid"
          data-from='{"opacity":0,"scale":"0.88"}'
          data-to='{"opacity":1,"scale":"1"}'
          data-start="0.3"
          data-end="0.56"
        >
          <div class="s2-pill s2-p1">opacity</div>
          <div class="s2-pill s2-p2">translateY</div>
          <div class="s2-pill s2-p3">translateX</div>
          <div class="s2-pill s2-p4">scale</div>
          <div class="s2-pill s2-p5">rotate</div>
          <div class="s2-pill s2-p6">any CSS</div>
        </div>

        <p
          class="s2-desc"
          data-from='{"opacity":0,"x":"-35px"}'
          data-to='{"opacity":1,"x":"0px"}'
          data-start="0.5"
          data-end="0.72"
        >Mix properties freely — scale, x, y, rotate, opacity —<br/>all driven by the same scroll offset.</p>

        <div
          class="s2-tech"
          data-from='{"opacity":0,"x":"-14px"}'
          data-to='{"opacity":0.5,"x":"0px"}'
          data-start="0.68"
          data-end="0.84"
        >technique: scale + x + opacity</div>

      </div>
    </motion-scene>

    <!-- ── Scene 03 — SEQUENCE (staggered y from below + rotate) -->
    <motion-scene height="220vh" class="scene">
      <div class="s3-body">

        <span
          class="s3-index"
          data-from='{"opacity":0,"y":"32px"}'
          data-to='{"opacity":1,"y":"0px"}'
          data-start="0.0"
          data-end="0.2"
        >003</span>

        <h2
          class="s3-title"
          data-from='{"opacity":0,"y":"65px"}'
          data-to='{"opacity":1,"y":"0px"}'
          data-start="0.1"
          data-end="0.35"
        >SEQUENCE</h2>

        <!-- Timeline bars — each one comes in separately from below -->
        <div class="s3-timeline">
          <div
            class="s3-row"
            data-from='{"opacity":0,"y":"30px"}'
            data-to='{"opacity":1,"y":"0px"}'
            data-start="0.28"
            data-end="0.46"
          >
            <span class="s3-el">element 1</span>
            <div class="s3-bar"><div class="s3-fill" style="left:0%;width:40%"></div></div>
            <span class="s3-range">0.0 → 0.4</span>
          </div>
          <div
            class="s3-row"
            data-from='{"opacity":0,"y":"30px"}'
            data-to='{"opacity":1,"y":"0px"}'
            data-start="0.38"
            data-end="0.56"
          >
            <span class="s3-el">element 2</span>
            <div class="s3-bar"><div class="s3-fill" style="left:25%;width:40%"></div></div>
            <span class="s3-range">0.25 → 0.65</span>
          </div>
          <div
            class="s3-row"
            data-from='{"opacity":0,"y":"30px"}'
            data-to='{"opacity":1,"y":"0px"}'
            data-start="0.48"
            data-end="0.66"
          >
            <span class="s3-el">element 3</span>
            <div class="s3-bar"><div class="s3-fill" style="left:55%;width:40%"></div></div>
            <span class="s3-range">0.55 → 0.95</span>
          </div>
        </div>

        <p
          class="s3-desc"
          data-from='{"opacity":0,"y":"20px"}'
          data-to='{"opacity":1,"y":"0px"}'
          data-start="0.6"
          data-end="0.8"
        >Stagger any elements by shifting their start and end offsets.<br/>No orchestration needed.</p>

        <div
          class="s3-tech"
          data-from='{"opacity":0,"y":"12px"}'
          data-to='{"opacity":0.5,"y":"0px"}'
          data-start="0.74"
          data-end="0.9"
        >technique: y (from below) · staggered start/end</div>

      </div>
    </motion-scene>

    <!-- ── Outro ───────────────────────────────────────────── -->
    <section class="outro">
      <p class="outro-text">Built with <code>motion-components</code> — declarative scroll animation, any framework.</p>
      <div class="outro-nav">
        <a href="/docs/scroll/motion-scene/" class="btn-ghost">← Docs</a>
        <a href="/showcase/parallax/" class="btn-solid">Parallax showcase →</a>
      </div>
    </section>

  </div>
</Layout>

<script>
  import "motion-components";
</script>

<style>
  .showcase {
    color: var(--color-text);
    min-height: 100vh;
  }

  /* ── Intro ────────────────────────────────────────────────── */
  .intro {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem;
    gap: 1.75rem;
    position: relative;
  }

  .intro-eyebrow {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.65;
  }

  .intro-title {
    font-size: clamp(68px, 13vw, 168px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.88;
    color: var(--color-text);
  }

  .intro-title em {
    color: var(--color-accent);
    opacity: 0.7;
  }

  .intro-body {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .intro-hint {
    position: absolute;
    bottom: 2.5rem;
    font-size: 1.4rem;
    color: var(--color-border);
    animation: bob 2.2s ease-in-out infinite;
  }

  @keyframes bob {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%       { transform: translateY(7px); opacity: 1; }
  }

  /* ── Shared scene base ────────────────────────────────────── */
  motion-scene.scene {
    display: block;
    border-top: 1px solid var(--color-border);
  }

  /* ── Scene 01 — slides down ───────────────────────────────── */
  .s1-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
    padding: 0 2rem;
    max-width: 680px;
    width: 100%;
  }

  .s1-index {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--color-accent);
    opacity: 0;
  }

  .s1-title {
    font-size: clamp(52px, 10vw, 130px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--color-text);
    opacity: 0;
  }

  .s1-desc {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.75;
    opacity: 0;
  }

  /* Code block stays dark — it's a terminal-style snippet */
  .s1-code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 2;
    background: #0c0c1e;
    border: 1px solid #1e1e38;
    color: #c8c8e8;
    border-radius: 12px;
    padding: 1.4rem 2rem;
    text-align: left;
    opacity: 0;
    width: 100%;
    max-width: 480px;
  }

  .s1-tech {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    opacity: 0;
  }

  .c-muted { color: #5858a8; }
  .c-str   { color: #86efac; }
  .c-num   { color: #fbbf24; }

  /* ── Scene 02 — scales ────────────────────────────────────── */
  .s2-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.5rem;
    padding: 0 2rem;
    max-width: 640px;
    width: 100%;
  }

  .s2-index {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #8b5cf6;
    opacity: 0;
  }

  .s2-title {
    font-size: clamp(52px, 10vw, 130px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #8b5cf6;
    opacity: 0;
  }

  .s2-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    opacity: 0;
  }

  .s2-pill {
    font-size: 0.72rem;
    font-weight: 500;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid;
    letter-spacing: 0.02em;
  }
  .s2-p1 { color: #9333ea; border-color: #9333ea40; background: #9333ea0d; }
  .s2-p2 { color: var(--color-accent); border-color: var(--color-border); background: var(--color-accent-dim); }
  .s2-p3 { color: #16a34a; border-color: #16a34a40; background: #16a34a0d; }
  .s2-p4 { color: #d97706; border-color: #d9770640; background: #d977060d; }
  .s2-p5 { color: #dc2626; border-color: #dc262640; background: #dc26260d; }
  .s2-p6 { color: var(--color-muted); border-color: var(--color-border); background: transparent; }

  .s2-desc {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.75;
    opacity: 0;
  }

  .s2-tech {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    opacity: 0;
  }

  /* ── Scene 03 — slides up ─────────────────────────────────── */
  .s3-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
    padding: 0 2rem;
    max-width: 660px;
    width: 100%;
  }

  .s3-index {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: #10b981;
    opacity: 0;
  }

  .s3-title {
    font-size: clamp(52px, 10vw, 130px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: #10b981;
    opacity: 0;
  }

  .s3-timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 500px;
  }

  .s3-row {
    display: grid;
    grid-template-columns: 80px 1fr 90px;
    gap: 0.8rem;
    align-items: center;
    opacity: 0;
  }

  .s3-el {
    font-size: 0.66rem;
    color: var(--color-muted);
    text-align: right;
  }

  .s3-range {
    font-size: 0.66rem;
    color: var(--color-muted);
  }

  .s3-bar {
    height: 2px;
    background: var(--color-border);
    border-radius: 999px;
    position: relative;
  }

  .s3-fill {
    position: absolute;
    top: 0;
    height: 100%;
    background: #10b981;
    border-radius: 999px;
    opacity: 0.6;
  }

  .s3-desc {
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.75;
    opacity: 0;
  }

  .s3-tech {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    opacity: 0;
  }

  /* ── Outro ────────────────────────────────────────────────── */
  .outro {
    padding: 14rem 2rem 8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }

  .outro-text {
    font-size: 1.05rem;
    color: var(--color-muted);
    line-height: 1.8;
  }

  .outro-text code {
    font-family: inherit;
    font-size: 0.88em;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-dim);
    padding: 0.15em 0.45em;
    border-radius: 4px;
  }

  .outro-nav {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-ghost, .btn-solid {
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 0.6rem 1.3rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .btn-ghost {
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    background: transparent;
  }
  .btn-ghost:hover { color: var(--color-text); background: var(--color-surface-2); text-decoration: none; }

  .btn-solid {
    color: var(--color-bg);
    background: var(--color-accent);
    border: 1px solid transparent;
  }
  .btn-solid:hover { opacity: 0.85; text-decoration: none; }
</style>
